{% extends 'base.html.twig' %}

{% block title %}{{ title }} - {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/pages/hand_3d/gallery.css') }}">
{% endblock %}

{% block body %}
<div class="gallery-container">
    <div class="container">
        <!-- Header -->
        <div class="gallery-header">
            <h1><i class="fas fa-images"></i> Galerie 3D Handi-3D</h1>
            <p class="lead">Découvrez notre collection de modèles 3D de prothèses de main</p>
            <a href="{{ path('handi_3d_index') }}" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left"></i> Retour à l'accueil
            </a>
        </div>

        <!-- Filters -->
        <div class="gallery-filters">
            <button class="filter-btn active" data-filter="all">Tous</button>
            <button class="filter-btn" data-filter="basic">Basique</button>
            <button class="filter-btn" data-filter="advanced">Avancé</button>
            <button class="filter-btn" data-filter="prosthetic">Prothèse</button>
            <button class="filter-btn" data-filter="mechanical">Mécanique</button>
        </div>

        <!-- Gallery Grid -->
        <div class="gallery-grid">
            <!-- Item 1 -->
            <div class="gallery-item" data-category="basic">
                <div class="gallery-item-image">
                    <div class="text-center">
                        <i class="fas fa-hand-paper fa-4x mb-2"></i>
                        <h4>Modèle Basique</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Main Anatomique de Base</div>
                    <div class="gallery-item-description">
                        Modèle 3D anatomiquement correct d'une main humaine avec articulations de base. Parfait pour l'apprentissage et les démonstrations.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Anatomique</span>
                        <span class="tag">Éducatif</span>
                        <span class="tag">Basique</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('basic-hand')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>

            <!-- Item 2 -->
            <div class="gallery-item" data-category="prosthetic">
                <div class="gallery-item-image" id="prosthetic-image">
                    <div class="text-center">
                        <i class="fas fa-hand-rock fa-4x mb-2"></i>
                        <h4>Prothèse Moderne</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Prothèse Myoélectrique</div>
                    <div class="gallery-item-description">
                        Modèle avancé de prothèse myoélectrique avec capteurs intégrés et contrôle par signaux musculaires.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Prothèse</span>
                        <span class="tag">Myoélectrique</span>
                        <span class="tag">Avancé</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('prosthetic-myo')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>

            <!-- Item 3 -->
            <div class="gallery-item" data-category="mechanical">
                <div class="gallery-item-image" id="mechanical-image">
                    <div class="text-center">
                        <i class="fas fa-cogs fa-4x mb-2"></i>
                        <h4>Main Mécanique</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Prothèse Mécanique</div>
                    <div class="gallery-item-description">
                        Conception mécanique traditionnelle avec système de câbles et harnais pour le contrôle des mouvements.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Mécanique</span>
                        <span class="tag">Traditionnel</span>
                        <span class="tag">Fiable</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('mechanical-hand')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>

            <!-- Item 4 -->
            <div class="gallery-item" data-category="advanced">
                <div class="gallery-item-image" id="advanced-image">
                    <div class="text-center">
                        <i class="fas fa-robot fa-4x mb-2"></i>
                        <h4>Main Bionique</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Prothèse Bionique Avancée</div>
                    <div class="gallery-item-description">
                        Technologie de pointe avec retour haptique, contrôle neural et doigts articulés indépendants.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Bionique</span>
                        <span class="tag">IA</span>
                        <span class="tag">Haptique</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('bionic-hand')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>

            <!-- Item 5 -->
            <div class="gallery-item" data-category="prosthetic">
                <div class="gallery-item-image" id="precision-image">
                    <div class="text-center">
                        <i class="fas fa-hand-scissors fa-4x mb-2"></i>
                        <h4>Préhension Fine</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Prothèse de Préhension</div>
                    <div class="gallery-item-description">
                        Spécialement conçue pour les tâches de préhension fine et les mouvements de précision.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Préhension</span>
                        <span class="tag">Précision</span>
                        <span class="tag">Spécialisé</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('precision-hand')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>

            <!-- Item 6 -->
            <div class="gallery-item" data-category="basic">
                <div class="gallery-item-image" id="pedagogical-image">
                    <div class="text-center">
                        <i class="fas fa-hand-peace fa-4x mb-2"></i>
                        <h4>Modèle Pédagogique</h4>
                    </div>
                </div>
                <div class="gallery-item-content">
                    <div class="gallery-item-title">Main Éducative Interactive</div>
                    <div class="gallery-item-description">
                        Modèle interactif pour l'enseignement de l'anatomie de la main et des principes de prothétique.
                    </div>
                    <div class="gallery-item-tags">
                        <span class="tag">Éducation</span>
                        <span class="tag">Interactif</span>
                        <span class="tag">Formation</span>
                    </div>
                    <div class="gallery-item-actions">
                        <a href="{{ path('handi_3d_viewer') }}" class="btn-gallery btn-view">
                            <i class="fas fa-eye"></i> Visualiser
                        </a>
                        <button class="btn-gallery btn-download" onclick="downloadModel('educational-hand')">
                            <i class="fas fa-download"></i> Télécharger
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de téléchargement -->
<div id="downloadModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h3><i class="fas fa-download"></i> Téléchargement du modèle</h3>
        <p>Le téléchargement du modèle 3D va commencer. Formats disponibles :</p>
        <ul>
            <li><strong>OBJ</strong> - Format universel</li>
            <li><strong>STL</strong> - Pour impression 3D</li>
            <li><strong>FBX</strong> - Avec animations</li>
            <li><strong>GLTF</strong> - Optimisé web</li>
        </ul>
        <div class="text-center mt-3">
            <button class="btn btn-primary" onclick="startDownload()">
                <i class="fas fa-download"></i> Commencer le téléchargement
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Filtrage de la galerie
        document.querySelectorAll('.filter-btn').forEach(button => {
            button.addEventListener('click', function() {
                // Mise à jour des boutons actifs
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                
                const filter = this.getAttribute('data-filter');
                const items = document.querySelectorAll('.gallery-item');
                
                items.forEach(item => {
                    if (filter === 'all' || item.getAttribute('data-category') === filter) {
                        item.style.display = 'block';
                        item.style.animation = 'fadeIn 0.5s ease';
                    } else {
                        item.style.display = 'none';
                    }
                });
            });
        });
        
        // Modal de téléchargement
        const modal = document.getElementById('downloadModal');
        const closeModal = document.querySelector('.close');
        
        closeModal.addEventListener('click', () => {
            modal.style.display = 'none';
        });
        
        window.addEventListener('click', (event) => {
            if (event.target === modal) {
                modal.style.display = 'none';
            }
        });
        
        // Fonction de téléchargement
        function downloadModel(modelId) {
            console.log(`Téléchargement du modèle: ${modelId}`);
            modal.style.display = 'block';
        }
        
        function startDownload() {
            // Simulation du téléchargement
            alert('Le téléchargement va commencer (simulation)');
            modal.style.display = 'none';
        }
        
        // Animation des cartes au chargement
        document.addEventListener('DOMContentLoaded', function() {
            const items = document.querySelectorAll('.gallery-item');
            items.forEach((item, index) => {
                item.style.opacity = '0';
                item.style.transform = 'translateY(30px)';
                
                setTimeout(() => {
                    item.style.transition = 'all 0.6s ease';
                    item.style.opacity = '1';
                    item.style.transform = 'translateY(0)';
                }, index * 150);
            });
        });
    </script>
{% endblock %}