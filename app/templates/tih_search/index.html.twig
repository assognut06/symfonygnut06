{% extends 'base.html.twig' %}

{% block title %}Recherche TIH{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tih_search') }}
{% endblock %}

{% block body %}
<main class="bg-main min-vh-100 py-5" role="main" 
      data-controller="tih-search"
      data-tih-search-url-value="{{ path('app_tih_search') }}"
      data-tih-search-profiles-value="{{ allTihs|map(profile => {
        'id': profile.id,
        'firstName': profile.firstName,
        'lastName': profile.lastName,
        'city': profile.city,
        'postalCode': profile.postalCode,
        'photo': profile.photo,
        'rate': profile.rate,
        'rateType': profile.rateType,
        'availability': profile.availability,
        'availabilityDate': profile.availabilityDate ? profile.availabilityDate|date('Y-m-d') : null
      })|json_encode|e('html_attr') }}"
      data-tih-search-api-key-value="{{ app.request.server.get('GNUT06MAPAPI') }}"
      data-tih-search-city-coordinates-value="{{ cityCoordinates|json_encode|e('html_attr') }}"
      data-action="popstate@window->tih-search&#35;handleBrowserNavigation">
    <div class="container-fluid">
        <header class="text-center mb-5">
            <h1 class="gradient-text mb-3">Recherche de Profils TIH</h1>
            <p class="text text-white">
                Découvrez nos Travailleurs Indépendants Handicapés et leurs compétences
            </p>
            {% if totalItems > 0 %}
                <p class="text-white-50 mt-2" data-tih-search-target="resultsInfo">
                    <i class="bi bi-info-circle me-1"></i>
                    {{ totalItems }} profil{{ totalItems > 1 ? 's' : '' }} trouvé{{ totalItems > 1 ? 's' : '' }}
                </p>
            {% endif %}
        </header>

        <div class="row">
            {# Sidebar with filters #}
            <aside class="col-lg-3 mb-4">
                <div class="card bg-dark border-secondary sticky-top" style="top: 1rem;">
                    <div class="card-body" data-tih-search-target="sidebar">
                        <h5 class="card-title text-white mb-4">
                            <i class="bi bi-funnel me-2"></i>Filtres
                        </h5>

                        <form id="filter-form" method="GET" action="{{ path('app_tih_search') }}"
                              data-tih-search-target="form">
                            {# Skills Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-briefcase me-2"></i>Compétences
                                </h6>
                                {% for skill in availableFilters.skills %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="skills[]" 
                                               value="{{ skill.id }}" 
                                               id="skill-{{ skill.id }}"
                                               data-action="change->tih-search&#35;filterChange"
                                               {% if skill.id in currentFilters.skills %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="skill-{{ skill.id }}">
                                            {{ skill.name }} <span class="badge bg-secondary">{{ skill.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Region Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-map me-2"></i>Régions
                                </h6>
                                {% for region in availableFilters.regions %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox region-checkbox" 
                                               type="checkbox" 
                                               name="regions[]" 
                                               value="{{ region.region }}" 
                                               data-action="change->tih-search&#35;regionChange"
                                               id="region-{{ region.region|replace({' ': '-', '\'': ''}) }}"
                                               {% if region.region in currentFilters.regions %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="region-{{ region.region|replace({' ': '-', '\'': ''}) }}">
                                            {{ region.region }} <span class="badge bg-secondary">{{ region.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Département Filter #}
                            <div class="filter-section mb-4" data-tih-search-target="departementSection">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-signpost me-2"></i>Départements
                                </h6>
                                <div data-tih-search-target="departementContainer">
                                {% for dept in availableFilters.departements %}
                                    <div class="form-check departement-item" 
                                         data-region="{{ dept.region }}"
                                         style="{% if currentFilters.regions is empty %}display: none;{% elseif dept.region not in currentFilters.regions %}display: none;{% endif %}">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="departements[]" 
                                               value="{{ dept.departement }}" 
                                               data-action="change->tih-search&#35;filterChange"
                                               data-region="{{ dept.region }}"
                                               id="dept-{{ dept.departement|replace({' ': '-', '\'': ''}) }}"
                                               {% if dept.departement in currentFilters.departements %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="dept-{{ dept.departement|replace({' ': '-', '\'': ''}) }}">
                                            {{ dept.departement }} <span class="badge bg-secondary">{{ dept.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                                </div>
                            </div>

                            {# Availability Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-clock me-2"></i>Disponibilité
                                </h6>
                                {% for avail in availableFilters.availability %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="availability[]" 
                                               value="{{ avail.availability }}" 
                                               data-action="change->tih-search&#35;filterChange"
                                               id="availability-{{ avail.availability|replace({' ': '-'}) }}"
                                               {% if avail.availability in currentFilters.availability %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="availability-{{ avail.availability|replace({' ': '-'}) }}">
                                            {{ avail.availability }} <span class="badge bg-secondary">{{ avail.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Rate Filter with Type #}
                            {% if availableFilters.minRate is not null and availableFilters.maxRate is not null %}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-cash me-2"></i>Fourchette de tarif
                                </h6>
                                <div class="mb-3">
                                    <label class="form-label text-white-50 small">
                                        <span id="rateValue">{{ currentFilters.minRate ?? availableFilters.minRate }}€ - {{ currentFilters.maxRate ?? availableFilters.maxRate }}€</span>
                                    </label>
                                    <div id="rateSlider" 
                                         class="mt-3 mb-3"
                                         data-min="{{ availableFilters.minRate }}"
                                         data-max="{{ availableFilters.maxRate }}"></div>
                                    <input type="hidden" name="minRate" id="minRateInput" value="{{ currentFilters.minRate ?? availableFilters.minRate }}">
                                    <input type="hidden" name="maxRate" id="maxRateInput" value="{{ currentFilters.maxRate ?? availableFilters.maxRate }}">
                                    <div class="d-flex justify-content-between text-white-50 small mt-1">
                                        <span>{{ availableFilters.minRate }}€</span>
                                        <span>{{ availableFilters.maxRate }}€</span>
                                    </div>
                                </div>
                                
                                {# Rate Type Radio Buttons #}
                                {% if availableFilters.rateTypes is not empty %}
                                <div class="mt-3">
                                    <label class="form-label text-white-50 small">Type</label>
                                    <div class="d-flex gap-3">
                                        <div class="form-check">
                                            <input class="form-check-input" 
                                                   type="radio" 
                                                   name="rateType" 
                                                   value="" 
                                                   data-action="change->tih-search&#35;filterChange"
                                                   id="rateTypeRadio-all"
                                                   {% if currentFilters.rateType is not defined or currentFilters.rateType == '' %}checked{% endif %}>
                                            <label class="form-check-label text-white-50" for="rateTypeRadio-all">
                                                Tous
                                            </label>
                                        </div>
                                        {% for rateType in availableFilters.rateTypes %}
                                            <div class="form-check">
                                                <input class="form-check-input" 
                                                       type="radio" 
                                                       name="rateType" 
                                                       value="{{ rateType.rateType }}" 
                                                       data-action="change->tih-search&#35;filterChange"
                                                       id="rateTypeRadio-{{ loop.index }}"
                                                       {% if currentFilters.rateType is defined and currentFilters.rateType == rateType.rateType %}checked{% endif %}>
                                                <label class="form-check-label text-white-50" for="rateTypeRadio-{{ loop.index }}">
                                                    {{ rateType.rateType == 'Horaire' ? 'Heure' : 'Jour' }}
                                                </label>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                            {% endif %}

                            <button type="button" id="clear-filters" class="btn btn-outline-light w-100"
                                    data-action="click->tih-search&#35;clearFilters">
                                <i class="bi bi-x-circle me-2"></i>Effacer les filtres
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            {# Main content #}
            <div class="col-lg-9">
                {# View Toggle #}
                <div class="mb-4 d-flex justify-content-end">
                    <div class="btn-group" role="group" aria-label="Vue">
                        <button type="button" 
                                class="btn btn-outline-light active" 
                                id="gridViewBtn"
                                data-action="click->tih-search#showGridView">
                            <i class="bi bi-grid-3x3-gap me-1"></i>Grille
                        </button>
                        <button type="button" 
                                class="btn btn-outline-light" 
                                id="mapViewBtn"
                                data-action="click->tih-search#showMapView">
                            <i class="bi bi-map me-1"></i>Carte
                        </button>
                    </div>
                </div>

                {# Loading overlay #}
                <div class="loading-overlay d-none" 
                     data-tih-search-target="loader">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Recherche en cours...</span>
                    </div>
                </div>

                {# Map View #}
                <div id="map-view" class="d-none mb-4" data-tih-search-target="mapView">
                    <div id="tih-map" style="height: calc(100vh - 200px); min-height: 600px; border-radius: 1rem;"></div>
                </div>

                {# Grille de cartes TIH #}
                <div id="tih-grid" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" 
                     role="list" 
                     aria-label="Liste des profils TIH"
                     data-tih-search-target="results">
                    {% for tih in tihs %}
                <article class="col d-flex" role="listitem">
                    <div class="card text-center h-100 bg-dark border-secondary" tabindex="0">
                        {% if tih.photo %}
                            <img src="{{ asset('uploads/tih/' ~ tih.photo) }}" 
                                 class="card-img-top img-fluid" 
                                 alt="Photo de profil de {{ tih.firstName }} {{ tih.lastName }}" 
                                 role="img">
                        {% else %}
                            <img src="{{ asset('images/user_profil.jpg') }}" 
                                 class="card-img-top img-fluid" 
                                 alt="Photo de profil par défaut" 
                                 role="img">
                        {% endif %}
                        
                        <div class="card-body d-flex flex-column bg-dark">
                            <h3 class="card-title text-white mb-2 h5">
                                {{ tih.firstName|default('') }} {{ tih.lastName|default('') }}
                            </h3>
                            
                            {% if tih.city or tih.postalCode %}
                                <p class="tih-location mb-2">
                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                    {{ tih.postalCode|default('') }} {{ tih.city|default('') }}
                                </p>
                            {% endif %}

                            {% if tih.competences is defined and tih.competences|length > 0 %}
                                <div class="mb-3 flex-grow-1">
                                    {% for competence in tih.competences|slice(0, 3) %}
                                        <span class="competence-badge">{{ competence }}</span>
                                    {% endfor %}
                                    {% if tih.competences|length > 3 %}
                                        <span class="competence-badge">+{{ tih.competences|length - 3 }}</span>
                                    {% endif %}
                                </div>
                            {% endif %}

                            {% if tih.rate and tih.rateType %}
                                <p class="text-white mb-2">
                                    <i class="bi bi-currency-euro me-1"></i>
                                    <strong>{{ tih.rate }}€</strong> / {{ tih.rateType }}
                                </p>
                            {% endif %}

                            {% if tih.availability %}
                                {% set availabilityClass = tih.availability|lower == 'disponible' ? 'disponible' : (tih.availability|lower == 'occupé' ? 'occupe' : 'partiellement') %}
                                <span class="availability-badge availability-{{ availabilityClass }}">
                                    {{ tih.availability }}
                                </span>
                            {% endif %}

                            <div class="mt-auto pt-3">
                                <a href="{{ path('app_tih_details', {'id': tih.id}) }}"
                                   class="btn btn-outline-light btn-sm w-100"
                                   aria-label="Voir le profil détaillé de {{ tih.firstName }} {{ tih.lastName }}">
                                    <i class="bi bi-eye me-2"></i>Voir le profil
                                </a>
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info text-center" role="status">
                        <i class="bi bi-info-circle me-2"></i>
                           Aucun profil TIH disponible.
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
            <nav aria-label="Navigation des pages de résultats" class="mt-5"
                 data-tih-search-target="pagination">
                <ul class="pagination justify-content-center">
                    {# Previous button #}
                    <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                        <a class="page-link" 
                           href="{{ currentPage > 1 ? path('app_tih_search', {'page': currentPage - 1}) : '#' }}"
                           aria-label="Page précédente"
                           data-action="click->tih-search&#35;handlePagination"
                           {{ currentPage == 1 ? 'tabindex="-1" aria-disabled="true"' : '' }}>
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    {# Page numbers #}
                    {% set startPage = max(1, currentPage - 2) %}
                    {% set endPage = min(totalPages, currentPage + 2) %}

                    {% if startPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" 
                               href="{{ path('app_tih_search', {'page': 1}) }}"
                               data-action="click->tih-search&#35;handlePagination">1</a>
                        </li>
                        {% if startPage > 2 %}
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        {% endif %}
                    {% endif %}

                    {% for page in startPage..endPage %}
                        <li class="page-item {{ page == currentPage ? 'active' : '' }}">
                            <a class="page-link" 
                               href="{{ path('app_tih_search', { 'page': page}) }}"
                               data-action="click->tih-search&#35;handlePagination">
                                {{ page }}
                                {% if page == currentPage %}
                                    <span class="visually-hidden">(page actuelle)</span>
                                {% endif %}
                            </a>
                        </li>
                    {% endfor %}

                    {% if endPage < totalPages %}
                        {% if endPage < totalPages - 1 %}
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        {% endif %}
                        <li class="page-item">
                            <a class="page-link" 
                               href="{{ path('app_tih_search', { 'page': totalPages}) }}"
                               data-action="click->tih-search&#35;handlePagination">{{ totalPages }}</a>
                        </li>
                    {% endif %}

                    {# Next button #}
                    <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                        <a class="page-link" 
                           href="{{ currentPage < totalPages ? path('app_tih_search', {'page': currentPage + 1}) : '#' }}"
                           aria-label="Page suivante"
                           data-action="click->tih-search&#35;handlePagination"
                           {{ currentPage == totalPages ? 'tabindex="-1" aria-disabled="true"' : '' }}>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
            </div>
        </div>
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
{% endblock %}
