{% extends 'base.html.twig' %}

{% block title %}Recherche TIH{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('tih_search') }}
{% endblock %}

{% block body %}
<main class="bg-main min-vh-100 py-5" role="main">
    <div class="container-fluid">
        <header class="text-center mb-5">
            <h1 class="gradient-text mb-3">Recherche de Profils TIH</h1>
            <p class="text text-white">
                Découvrez nos Travailleurs Indépendants Handicapés et leurs compétences
            </p>
            {% if totalItems > 0 %}
                <p class="text-white-50 mt-2">
                    <i class="bi bi-info-circle me-1"></i>
                    {{ totalItems }} profil{{ totalItems > 1 ? 's' : '' }} trouvé{{ totalItems > 1 ? 's' : '' }}
                </p>
            {% endif %}
        </header>

        <div class="row">
            {# Sidebar with filters #}
            <aside class="col-lg-3 mb-4">
                <div class="card bg-dark border-secondary sticky-top" style="top: 1rem;">
                    <div class="card-body">
                        <h5 class="card-title text-white mb-4">
                            <i class="bi bi-funnel me-2"></i>Filtres
                        </h5>

                        <form id="filter-form" method="GET" action="{{ path('app_tih_search') }}">
                            {# Competences Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-briefcase me-2"></i>Compétences
                                </h6>
                                {% for competence in availableFilters.competences %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="competences[]" 
                                               value="{{ competence.id }}" 
                                               id="competence-{{ competence.id }}"
                                               {% if competence.id in currentFilters.competences %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="competence-{{ competence.id }}">
                                            {{ competence.name }} <span class="badge bg-secondary">{{ competence.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Cities Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-geo-alt me-2"></i>Villes
                                </h6>
                                {% for ville in availableFilters.villes %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="villes[]" 
                                               value="{{ ville.ville }}" 
                                               id="ville-{{ ville.ville|replace({' ': '-'}) }}"
                                               {% if ville.ville in currentFilters.villes %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="ville-{{ ville.ville|replace({' ': '-'}) }}">
                                            {{ ville.ville }} ({{ ville.codePostal }}) <span class="badge bg-secondary">{{ ville.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# Availability Filter #}
                            <div class="filter-section mb-4">
                                <h6 class="text-white mb-3">
                                    <i class="bi bi-clock me-2"></i>Disponibilité
                                </h6>
                                {% for dispo in availableFilters.disponibilites %}
                                    <div class="form-check">
                                        <input class="form-check-input filter-checkbox" 
                                               type="checkbox" 
                                               name="disponibilite[]" 
                                               value="{{ dispo.disponibilite }}" 
                                               id="dispo-{{ dispo.disponibilite|replace({' ': '-'}) }}"
                                               {% if dispo.disponibilite in currentFilters.disponibilite %}checked{% endif %}>
                                        <label class="form-check-label text-white-50" for="dispo-{{ dispo.disponibilite|replace({' ': '-'}) }}">
                                            {{ dispo.disponibilite }} <span class="badge bg-secondary">{{ dispo.count }}</span>
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            <button type="button" id="clear-filters" class="btn btn-outline-light w-100">
                                <i class="bi bi-x-circle me-2"></i>Effacer les filtres
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            {# Main content #}
            <div class="col-lg-9">
                {# Loading overlay #}
                <div id="search-loader" class="search-loader-overlay" style="display: none;">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Recherche en cours...</span>
                    </div>
                </div>

        {# Grille de cartes TIH #}
        <div id="tih-grid" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4" role="list" aria-label="Liste des profils TIH">
            {% for tih in tihs %}
                <article class="col d-flex" role="listitem">
                    <div class="card text-center h-100 bg-dark border-secondary" tabindex="0">
                        {% if tih.photo %}
                            <img src="{{ asset('uploads/tih/' ~ tih.photo) }}" 
                                 class="card-img-top img-fluid" 
                                 alt="Photo de profil de {{ tih.prenom }} {{ tih.nom }}" 
                                 role="img">
                        {% else %}
                            <img src="{{ asset('images/user_profil.jpg') }}" 
                                 class="card-img-top img-fluid" 
                                 alt="Photo de profil par défaut" 
                                 role="img">
                        {% endif %}
                        
                        <div class="card-body d-flex flex-column bg-dark">
                            <h3 class="card-title text-white mb-2 h5">
                                {{ tih.prenom|default('') }} {{ tih.nom|default('') }}
                            </h3>
                            
                            {% if tih.ville or tih.codePostal %}
                                <p class="tih-location mb-2">
                                    <i class="bi bi-geo-alt-fill me-1"></i>
                                    {{ tih.codePostal|default('') }} {{ tih.ville|default('') }}
                                </p>
                            {% endif %}

                            {% if tih.competences is defined and tih.competences|length > 0 %}
                                <div class="mb-3 flex-grow-1">
                                    {% for competence in tih.competences|slice(0, 3) %}
                                        <span class="competence-badge">{{ competence }}</span>
                                    {% endfor %}
                                    {% if tih.competences|length > 3 %}
                                        <span class="competence-badge">+{{ tih.competences|length - 3 }}</span>
                                    {% endif %}
                                </div>
                            {% endif %}

                            {% if tih.disponibilite %}
                                {% set availabilityClass = tih.disponibilite|lower == 'disponible' ? 'disponible' : (tih.disponibilite|lower == 'occupé' ? 'occupe' : 'partiellement') %}
                                <span class="availability-badge availability-{{ availabilityClass }}">
                                    {{ tih.disponibilite }}
                                </span>
                            {% endif %}

                            <div class="mt-auto pt-3">
                                <a href="{{ path('app_tih_details', {'id': tih.id}) }}"
                                   class="btn btn-outline-light btn-sm w-100"
                                   aria-label="Voir le profil détaillé de {{ tih.prenom }} {{ tih.nom }}">
                                    <i class="bi bi-eye me-2"></i>Voir le profil
                                </a>
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-info text-center" role="status">
                        <i class="bi bi-info-circle me-2"></i>
                        {% if searchTerm %}
                            Aucun profil TIH trouvé pour "{{ searchTerm }}".
                        {% else %}
                            Aucun profil TIH disponible.
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
            <nav aria-label="Navigation des pages de résultats" class="mt-5">
                <ul class="pagination justify-content-center">
                    {# Previous button #}
                    <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                        <a class="page-link" 
                           href="{{ currentPage > 1 ? path('app_tih_search', {'q': searchTerm, 'page': currentPage - 1}) : '#' }}"
                           aria-label="Page précédente"
                           {{ currentPage == 1 ? 'tabindex="-1" aria-disabled="true"' : '' }}>
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    {# Page numbers #}
                    {% set startPage = max(1, currentPage - 2) %}
                    {% set endPage = min(totalPages, currentPage + 2) %}

                    {% if startPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_tih_search', {'q': searchTerm, 'page': 1}) }}">1</a>
                        </li>
                        {% if startPage > 2 %}
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        {% endif %}
                    {% endif %}

                    {% for page in startPage..endPage %}
                        <li class="page-item {{ page == currentPage ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('app_tih_search', {'q': searchTerm, 'page': page}) }}">
                                {{ page }}
                                {% if page == currentPage %}
                                    <span class="visually-hidden">(page actuelle)</span>
                                {% endif %}
                            </a>
                        </li>
                    {% endfor %}

                    {% if endPage < totalPages %}
                        {% if endPage < totalPages - 1 %}
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        {% endif %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_tih_search', {'q': searchTerm, 'page': totalPages}) }}">{{ totalPages }}</a>
                        </li>
                    {% endif %}

                    {# Next button #}
                    <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                        <a class="page-link" 
                           href="{{ currentPage < totalPages ? path('app_tih_search', {'q': searchTerm, 'page': currentPage + 1}) : '#' }}"
                           aria-label="Page suivante"
                           {{ currentPage == totalPages ? 'tabindex="-1" aria-disabled="true"' : '' }}>
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('tih_search') }}
{% endblock %}
